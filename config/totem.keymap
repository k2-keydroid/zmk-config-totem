/*
 * TOTEM (38-key) ZMK keymap
 * Base: original_frequency_layout (custom Eucalyn-derived romaji layout)
 * Designed with Claude, 2026-07
 *
 * Verified against the official GEIGEIGEIST/zmk-config-totem/config/totem.keymap
 * physical matrix layout (fetched 2026-07-01):
 *
 *   Row1 (top):    5 left + 5 right                = 10 keys
 *   Row2 (home):   5 left + 5 right                = 10 keys
 *   Row3 (bottom): 1 outer-pinky + 5 left + 5 right + 1 outer-pinky = 12 keys
 *   Row4 (thumbs): 3 left + 3 right                = 6 keys
 *   TOTAL = 38 keys
 *
 * IMPORTANT: the outer pinky key sits at the START of row3 on the left hand
 * and the END of row3 on the right hand (confirmed from official source),
 * NOT as a separate row as in earlier drafts of this file.
 *
 * NOTE on layer comments below: for readability, the outer-pinky pair is
 * drawn as its own visual row ("Pinky" line) between Row3 and the thumbs,
 * even though in the bindings they are physically part of the 12-key Row3.
 *
 * Layers:
 *   0: Base   - original_frequency_layout + thumbs
 *   1: NUM    - Numpad/Symbols, held via left thumb key 1 (&mo NUM)
 *   2: NAV    - Nav/Editing, held via left thumb key 2 (&mo NAV)
 *   3: FUNC   - Fkeys/Special, held via NUM+NAV combo (tri-layer)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE 0
#define NUM  1
#define NAV  2
#define FUNC 3

/ {
    // Tri-layer: holding NUM + NAV together activates FUNC
    // (mirrors the official repo's &mo ADJ pattern, but via conditional-layers
    //  instead of a physical third thumb key, since our thumb keys are already
    //  fully assigned to Space/Enter/Win)
    conditional_layers {
        compatible = "zmk,conditional-layers";
        tri_layer {
            if-layers = <NUM NAV>;
            then-layer = <FUNC>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        layer_base {
            label = "BASE";
            // ------------------------------------------------------------------
            // Row1:  Q    W    O    F    ;   |   M    R    D    Y    P
            // Row2:  U    I    A    E    ,   |   H    N    T    S    K
            // Row3:  Z    X    C    V    .   |   B    G    J    L    /
            // Pinky: Shift                   |                       -
            // Thumb: Layer2(NAV)  Layer1(NUM)  Space | Enter  BS  Win
            // (2026-07 update: I<->, swap and F<->. swap based on
            //  heatmap analysis + user's subjective comfort. , and . are
            //  now vertically aligned so Shift gives < and > in a column.
            //  v3 update: I <-> O swap, home row vowels are now U I A E.
            //  v4 update after first hands-on: BS <-> Shift swapped
            //  (Shift to outer pinky, BS to thumb), NAV/NUM thumbs swapped)
            // ------------------------------------------------------------------
            bindings = <
&kp Q      &kp W      &kp O      &kp F      &kp SEMI          &kp M      &kp R      &kp D      &kp Y      &kp P
&kp U      &kp I      &kp A      &kp E      &kp COMMA         &kp H      &kp N      &kp T      &kp S      &kp K
&kp LSHFT  &kp Z      &kp X      &kp C      &kp V      &kp DOT &kp B     &kp G      &kp J      &kp L      &kp FSLH   &kp MINUS
                       &mo NAV    &mo NUM    &kp SPACE         &kp RET    &kp BSPC   &kp LGUI
            >;
        };

        layer_num {
            label = "NUM";
            // ------------------------------------------------------------------
            // Row1:  [    ]    {    }    !   |   /    7    8    9    -
            // Row2:  @    &    ^    '    :   |   *    4    5    6    +
            // Row3:  `    ~    |    \    <   |   0    1    2    3    .
            // Pinky: TAB                     |                       =
            // (v5: right hand operators rearranged calculator-style.
            //  DQT removed from this layer; type it as Shift + ' instead.)
            // Thumb: Layer2  Layer1  Space   |   Enter  Shift  Win
            // ------------------------------------------------------------------
            bindings = <
&kp LBKT   &kp RBKT   &kp LBRC   &kp RBRC   &kp EXCL          &kp FSLH   &kp N7     &kp N8     &kp N9     &kp MINUS
&kp AT     &kp AMPS   &kp CARET  &kp SQT    &kp COLON         &kp ASTRK  &kp N4     &kp N5     &kp N6     &kp PLUS
&kp TAB    &kp GRAVE  &kp TILDE  &kp PIPE   &kp BSLH   &kp LT &kp N0     &kp N1     &kp N2     &kp N3     &kp DOT    &kp EQUAL
                       &mo NAV    &mo NUM    &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };

        layer_nav {
            label = "NAV";
            // ------------------------------------------------------------------
            // Row1:  Ctrl+Z    Ctrl+Y     ---   ---   Ctrl+P | ---     Home  Up    End    PgUp
            // Row2:  Win+Space Ctrl+Space Alt   Tab   --- | ---     Left  Down  Right  ---
            // Row3:  無変換    変換       ---   ---   ---    | Ctrl+F  ---   ---   ---    PgDn
            // Pinky: ESC                                     |                             Del
            // Thumb: Layer2  Layer1  Space                   | Enter  Shift  Win
            //
            // Arrow inverted-T on right hand (v4: moved up to home row):
            //   Row1: Up on T-column / Row2: Left(N) Down(T) Right(S)
            // ------------------------------------------------------------------
            bindings = <
&kp LC(Z)      &kp LC(Y)      &none      &none      &kp LC(P)         &none      &kp HOME   &kp UP     &kp END    &kp PG_UP
&kp LG(SPACE)  &kp LC(SPACE)  &kp LALT   &kp TAB    &none             &none      &kp LEFT   &kp DOWN   &kp RIGHT  &none
&kp ESC        &kp INT_MUHENKAN &kp INT_HENKAN &none &none      &none &kp LC(F)  &none      &none      &none      &kp PG_DN  &kp DEL
                              &mo NAV    &mo NUM    &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };

        layer_func {
            label = "FUNC";
            // ------------------------------------------------------------------
            // Row1:  F1      F2      F3      F4      F5      | F6       F7      F8      F9      F10
            // Row2:  BT_0    BT_1    BT_2    BT_3    BT_4    | ---      Ctrl+C  Ctrl+X  Ctrl+V  F11
            // Row3:  C+A+Del Ctrl+B  Ctrl+I  Ctrl+U  ---     | OUT_TOG  Ctrl+A  Ctrl+S  Ctrl+P  F12
            // Pinky: BT_CLR                                  |                                  Alt+F4
            // Thumb: Layer2  Layer1  Space                   | Enter  Shift  Win
            //
            // BT keys (2026-07 update, after first pairing troubleshoot):
            //   BT_SEL 0-4 on left home row: position = profile number, no memorizing.
            //   BT_CLR on left outer-pinky, C+A+Del next to it: dangerous keys
            //   grouped in the far-left corner. Alt+F4 stays on right outer-pinky.
            //   BT_CLR clears pairing of CURRENT profile only.
            //   OUT_TOG (USB/BLE output toggle) on right H-column bottom.
            //   Edit keys: Ctrl+C/X/V on right home row, Ctrl+A/S/P below them.
            // ------------------------------------------------------------------
            bindings = <
&kp F1         &kp F2     &kp F3     &kp F4     &kp F5            &kp F6     &kp F7     &kp F8     &kp F9     &kp F10
&bt BT_SEL 0   &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4 &none    &kp LC(C)  &kp LC(X)  &kp LC(V)  &kp F11
&bt BT_CLR     &kp LC(LA(DEL)) &kp LC(B) &kp LC(I) &kp LC(U) &none &out OUT_TOG &kp LC(A) &kp LC(S) &kp LC(P) &kp F12  &kp LA(F4)
                          &mo NAV    &mo NUM    &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };
    };
};
