/*
 * TOTEM (38-key) ZMK keymap
 * Base: original_frequency_layout (custom Eucalyn-derived romaji layout)
 * Designed with Claude, 2026-07
 *
 * Verified against the official GEIGEIGEIST/zmk-config-totem/config/totem.keymap
 * physical matrix layout (fetched 2026-07-01):
 *
 *   Row1 (top):    5 left + 5 right                = 10 keys
 *   Row2 (home):   5 left + 5 right                = 10 keys
 *   Row3 (bottom): 1 outer-pinky + 5 left + 5 right + 1 outer-pinky = 12 keys
 *   Row4 (thumbs): 3 left + 3 right                = 6 keys
 *   TOTAL = 38 keys
 *
 * IMPORTANT: the outer pinky key sits at the START of row3 on the left hand
 * and the END of row3 on the right hand (confirmed from official source),
 * NOT as a separate row as in earlier drafts of this file.
 *
 * NOTE on layer comments below: for readability, the outer-pinky pair is
 * drawn as its own visual row ("Pinky" line) between Row3 and the thumbs,
 * even though in the bindings they are physically part of the 12-key Row3.
 *
 * Layers:
 *   0: BASE   - original_frequency_layout + thumbs (JIS-mode shift pairs)
 *   1: UBASE  - US-mode overlay, toggled via FUNC. Only 3 keys differ from
 *               BASE (see layer comment); everything else is &trans.
 *   2: NUM_J  - Numpad/Symbols for JIS-configured OS (JP_* codes + morphs)
 *   3: NUM_U  - Numpad/Symbols for US-configured OS (plain codes)
 *   4: NAV    - Nav/Editing, held via left thumb key 2 (&mo NAV)
 *   5: FUNC   - Fkeys/Special/BT/mode toggle, via NUM+NAV tri-layer
 *
 * ------------------------------------------------------------------
 * v6 (2026-07): JIS-mode US emulation
 *   OS side stays on 日本語キーボード(106/109). The keymap sends
 *   JIS-interpreted keycodes (keys_jp.h aliases) so that the OUTPUT
 *   matches US layout exactly, including shifted pairs.
 *   - keys_jp.h (same directory) provides JP_* aliases.
 *   - 12 mod-morphs implement US-style Shift pairs where JIS differs:
 *       Base : ;/:  -/_
 *       NUM_J: '/"  `/~  \/|  =/+  2/@  6/^  7/&  8/*  9/(  0/)
 *   - mod-morph masks the physical Shift automatically, then the
 *     morphed binding applies its own LS() where JIS needs it.
 *   - Unchanged because JIS == US for these shift pairs:
 *       ,/<  ./>  //?  1/!  3/#  4/$  5/%
 *   - NOTE: plain GRAVE keycode acts as 半角/全角 on JIS OS. Not used
 *     anywhere in this keymap; IME toggle is Ctrl+Space (already on NAV).
 *
 * v7 (2026-07): JIS/US dual mode
 *   - Added UBASE overlay + NUM_U layer for US-configured hosts.
 *   - Mode toggle (&tog UBASE) on FUNC, right hand H-column Row2,
 *     directly above OUT_TOG (output-related toggles share a column).
 *   - Tri-layer condition duplicated for both NUM variants.
 *   - Layer state is NOT persistent: after power-off/reset the keyboard
 *     always boots in JIS mode (UBASE off). No visual indicator; verify
 *     mode by typing Shift+; and checking the output.
 *   - Verified 2026-07: JIS mode on JIS host (all keys), US mode on JIS
 *     host (expected mojibake pattern = toggle works), US mode on US host
 *     (all keys). Fully operational in both environments.
 *
 * v8 (2026-07): NUM hands swapped + FUNC edit keys rearranged
 *   - NUM_J/NUM_U: left and right 5x3 blocks swapped. Numbers and
 *     operators now on the LEFT hand, brackets/symbols on the RIGHT.
 *     Right-thumb Shift + left-hand numbers is now a two-hand combo.
 *     Pinky keys (TAB / =) and thumbs unchanged. All mod-morphs move
 *     with their keys; behavior identical, position only.
 *   - FUNC: Ctrl+B/I/U <-> Ctrl+C/X/V swapped between hands, and the
 *     paste group reordered to X,C,V so that each aligns with the BASE
 *     letter column (Ctrl+X on X, Ctrl+C on C, Ctrl+V on V) - nothing
 *     new to memorize. Left-hand-only copy/paste now works while the
 *     right hand stays on the mouse (NUM+NAV thumbs + X/C/V are all
 *     left-hand). Format keys B/I/U move to right home row.
 *
 * v9 (2026-07): NAV PgDn moved up one row
 *   - PgDn: Row3 K-column -> Row2 K-column (was &none). PgUp/PgDn now
 *     stack vertically in the K-column, mirroring the Up/Down pair.
 *     Old Row3 position becomes &none.
 *
 * v10 (2026-07): NAV Ctrl added
 *   - LCTRL on Row2 right of Tab (was &none). Held together with the
 *     NAV thumb, this enables Ctrl+arrow / Ctrl+Home/End / Ctrl+PgUp/PgDn
 *     combos (word jump, document jump, browser tab switch) without
 *     leaving the NAV layer. Also usable as Ctrl+Tab via same-row Tab.
 * ------------------------------------------------------------------
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include "keys_jp.h"

#define BASE  0
#define UBASE 1
#define NUM_J 2
#define NUM_U 3
#define NAV   4
#define FUNC  5

/* Shorthand for mod-morph definitions (US-style shift pair on JIS OS) */
#define US_MORPH(name, unshifted, shifted)                    \
    name: name {                                              \
        compatible = "zmk,behavior-mod-morph";                \
        #binding-cells = <0>;                                 \
        bindings = <&kp unshifted>, <&kp shifted>;            \
        mods = <(MOD_LSFT|MOD_RSFT)>;                         \
    }

/ {
    // Tri-layer: holding NUM + NAV together activates FUNC.
    // Duplicated for both NUM variants so FUNC is reachable in either
    // mode regardless of which NUM layer the thumb activated.
    conditional_layers {
        compatible = "zmk,conditional-layers";
        tri_layer_jis {
            if-layers = <NUM_J NAV>;
            then-layer = <FUNC>;
        };
        tri_layer_us {
            if-layers = <NUM_U NAV>;
            then-layer = <FUNC>;
        };
    };

    behaviors {
        /* --- BASE layer (JIS mode) --- */
        US_MORPH(mm_semi_cln,  JP_SEMI,  JP_COLON);  /* ; : */
        US_MORPH(mm_mins_und,  JP_MINUS, JP_UNDER);  /* - _ */

        /* --- NUM_J layer: symbols --- */
        US_MORPH(mm_sqt_dqt,   JP_SQT,   JP_DQT);    /* ' " */
        US_MORPH(mm_grv_tld,   JP_GRAVE, JP_TILDE);  /* ` ~ */
        US_MORPH(mm_bslh_pipe, JP_BSLH,  JP_PIPE);   /* \ | */
        US_MORPH(mm_eq_plus,   JP_EQUAL, JP_PLUS);   /* = + */

        /* --- NUM_J layer: US-style Shift+number --- */
        US_MORPH(mm_2_at,      N2,       JP_AT);     /* 2 @ */
        US_MORPH(mm_6_crt,     N6,       JP_CARET);  /* 6 ^ */
        US_MORPH(mm_7_amps,    N7,       JP_AMPS);   /* 7 & */
        US_MORPH(mm_8_ast,     N8,       JP_ASTRK);  /* 8 * */
        US_MORPH(mm_9_lpar,    N9,       JP_LPAR);   /* 9 ( */
        US_MORPH(mm_0_rpar,    N0,       JP_RPAR);   /* 0 ) */
    };

    keymap {
        compatible = "zmk,keymap";

        layer_base {
            label = "BASE";
            // ------------------------------------------------------------------
            // Row1:  Q    W    O    F    ;   |   M    R    D    Y    P
            // Row2:  U    I    A    E    ,   |   H    N    T    S    K
            // Row3:  Z    X    C    V    .   |   B    G    J    L    /
            // Pinky: Shift                   |                       -
            // Thumb: Layer2(NAV)  Layer1(NUM_J)  Space | Enter  BS  Win
            // (2026-07 update: I<->, swap and F<->. swap based on
            //  heatmap analysis + user's subjective comfort. , and . are
            //  now vertically aligned so Shift gives < and > in a column.
            //  v3 update: I <-> O swap, home row vowels are now U I A E.
            //  v4 update after first hands-on: BS <-> Shift swapped
            //  (Shift to outer pinky, BS to thumb), NAV/NUM thumbs swapped.
            //  v6 update: ; and - are now mod-morphs so Shift gives : and _
            //  on a JIS-configured OS, exactly like US layout.)
            // ------------------------------------------------------------------
            bindings = <
&kp Q      &kp W      &kp O      &kp F      &mm_semi_cln      &kp M      &kp R      &kp D      &kp Y      &kp P
&kp U      &kp I      &kp A      &kp E      &kp COMMA         &kp H      &kp N      &kp T      &kp S      &kp K
&kp LSHFT  &kp Z      &kp X      &kp C      &kp V      &kp DOT &kp B     &kp G      &kp J      &kp L      &kp FSLH   &mm_mins_und
                       &mo NAV    &mo NUM_J  &kp SPACE         &kp RET    &kp BSPC   &kp LGUI
            >;
        };

        layer_ubase {
            label = "UBASE";
            // ------------------------------------------------------------------
            // US-mode overlay, toggled from FUNC (&tog UBASE).
            // Only 3 keys differ from BASE; all others are &trans so any
            // future BASE layout change automatically applies here too:
            //   Row1 ';'   : mod-morph not needed -> plain SEMI
            //                (US OS natively gives ; / Shift -> :)
            //   Pinky '-'  : mod-morph not needed -> plain MINUS
            //                (US OS natively gives - / Shift -> _)
            //   NUM thumb  : &mo NUM_U instead of &mo NUM_J
            // ------------------------------------------------------------------
            bindings = <
&trans     &trans     &trans     &trans     &kp SEMI          &trans     &trans     &trans     &trans     &trans
&trans     &trans     &trans     &trans     &trans            &trans     &trans     &trans     &trans     &trans
&trans     &trans     &trans     &trans     &trans     &trans &trans     &trans     &trans     &trans     &trans     &kp MINUS
                       &trans     &mo NUM_U  &trans            &trans     &trans     &trans
            >;
        };

        layer_num_jis {
            label = "NUM_J";
            // ------------------------------------------------------------------
            // Row1:  /    7    8    9    -   |   [    ]    {    }    !
            // Row2:  *    4    5    6    +   |   @    &    ^    '    :
            // Row3:  0    1    2    3    .   |   `    ~    |    \    <
            // Pinky: TAB                     |                       =
            // (v5: right hand operators rearranged calculator-style.
            //  DQT removed from this layer; type it as Shift + ' instead.
            //  v6: all symbols converted to JP_* codes for JIS OS.
            //  Shift+number gives US symbols via mod-morph:
            //  Shift+ 2 6 7 8 9 0 -> @ ^ & * ( ) . Shift+ 1 3 4 5 are
            //  already US-identical on JIS. Shift+ ' ` \ = -> " ~ | +.
            //  v8: left/right 5x3 blocks swapped. Numbers+operators on the
            //  left hand, brackets/symbols on the right. Right-thumb Shift
            //  + left-hand number is now a comfortable two-hand combo.)
            // Thumb: Layer2  Layer1  Space   |   Enter  Shift  Win
            // ------------------------------------------------------------------
            bindings = <
&kp FSLH    &mm_7_amps  &mm_8_ast   &mm_9_lpar  &mm_mins_und    &kp JP_LBKT &kp JP_RBKT &kp JP_LBRC &kp JP_RBRC &kp JP_EXCL
&kp JP_ASTRK &kp N4     &kp N5      &mm_6_crt   &kp JP_PLUS     &kp JP_AT   &kp JP_AMPS &kp JP_CARET &mm_sqt_dqt &kp JP_COLON
&kp TAB    &mm_0_rpar  &kp N1      &mm_2_at    &kp N3     &kp DOT &mm_grv_tld &kp JP_TILDE &kp JP_PIPE &mm_bslh_pipe &kp JP_LT &mm_eq_plus
                       &mo NAV    &mo NUM_J  &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };

        layer_num_us {
            label = "NUM_U";
            // ------------------------------------------------------------------
            // Same visual layout as NUM_J, but plain US keycodes.
            // On a US-configured OS, Shift+number natively produces US
            // symbols, so no mod-morphs are needed here.
            // Row1:  /    7    8    9    -   |   [    ]    {    }    !
            // Row2:  *    4    5    6    +   |   @    &    ^    '    :
            // Row3:  0    1    2    3    .   |   `    ~    |    \    <
            // Pinky: TAB                     |                       =
            // Thumb: Layer2  Layer1  Space   |   Enter  Shift  Win
            // ------------------------------------------------------------------
            bindings = <
&kp FSLH   &kp N7     &kp N8     &kp N9     &kp MINUS         &kp LBKT   &kp RBKT   &kp LBRC   &kp RBRC   &kp EXCL
&kp ASTRK  &kp N4     &kp N5     &kp N6     &kp PLUS          &kp AT     &kp AMPS   &kp CARET  &kp SQT    &kp COLON
&kp TAB    &kp N0     &kp N1     &kp N2     &kp N3     &kp DOT &kp GRAVE &kp TILDE  &kp PIPE   &kp BSLH   &kp LT     &kp EQUAL
                       &mo NAV    &mo NUM_U  &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };

        layer_nav {
            label = "NAV";
            // ------------------------------------------------------------------
            // Row1:  Ctrl+Z    Ctrl+Y     ---   ---   Ctrl+P | ---     Home  Up    End    PgUp
            // Row2:  Win+Space Ctrl+Space Alt   Tab   Ctrl | ---     Left  Down  Right  PgDn
            // Row3:  無変換    変換       ---   ---   ---    | Ctrl+F  ---   ---   ---    ---
            // Pinky: ESC                                     |                             Del
            // Thumb: Layer2  Layer1  Space                   | Enter  Shift  Win
            //
            // Arrow inverted-T on right hand (v4: moved up to home row):
            //   Row1: Up on T-column / Row2: Left(N) Down(T) Right(S)
            // (v6 note: Ctrl+Space here doubles as the IME 半角/全角 toggle
            //  per user's Windows IME configuration.
            //  v7 note: NUM thumb here points at NUM_J, but even in US mode
            //  the tri_layer_jis condition then lands on FUNC, so FUNC is
            //  reachable in both modes with either press order.)
            // ------------------------------------------------------------------
            bindings = <
&kp LC(Z)      &kp LC(Y)      &none      &none      &kp LC(P)         &none      &kp HOME   &kp UP     &kp END    &kp PG_UP
&kp LG(SPACE)  &kp LC(SPACE)  &kp LALT   &kp TAB    &kp LCTRL         &none      &kp LEFT   &kp DOWN   &kp RIGHT  &kp PG_DN
&kp ESC        &kp INT_MUHENKAN &kp INT_HENKAN &none &none      &none &kp LC(F)  &none      &none      &none      &none      &kp DEL
                              &mo NAV    &mo NUM_J  &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };

        layer_func {
            label = "FUNC";
            // ------------------------------------------------------------------
            // Row1:  F1      F2      F3      F4      F5      | F6       F7      F8      F9      F10
            // Row2:  BT_0    BT_1    BT_2    BT_3    BT_4    | JIS/US   Ctrl+B  Ctrl+I  Ctrl+U  F11
            // Row3:  C+A+Del Ctrl+X  Ctrl+C  Ctrl+V  ---     | OUT_TOG  Ctrl+A  Ctrl+S  Ctrl+P  F12
            // Pinky: BT_CLR                                  |                                  Alt+F4
            // Thumb: Layer2  Layer1  Space                   | Enter  Shift  Win
            //
            // BT keys (2026-07 update, after first pairing troubleshoot):
            //   BT_SEL 0-4 on left home row: position = profile number, no memorizing.
            //   BT_CLR on left outer-pinky, C+A+Del next to it: dangerous keys
            //   grouped in the far-left corner. Alt+F4 stays on right outer-pinky.
            //   BT_CLR clears pairing of CURRENT profile only.
            //   OUT_TOG (USB/BLE output toggle) on right H-column bottom.
            // v7: JIS/US mode toggle (&tog UBASE) on right H-column Row2,
            //   directly above OUT_TOG: output-related toggles share a column.
            //   Defaults to JIS mode on every power-up (layer state is not
            //   persisted). Quick mode check: type Shift+; and see what comes out.
            // v8: Ctrl+X/C/V moved to LEFT Row3, aligned with the BASE letter
            //   columns (Ctrl+X on X, Ctrl+C on C, Ctrl+V on V - zero
            //   memorization). Left-hand-only copy/paste while the right hand
            //   is on the mouse. Ctrl+B/I/U (format keys) moved to right
            //   home row where Ctrl+C/X/V used to be.
            // ------------------------------------------------------------------
            bindings = <
&kp F1         &kp F2     &kp F3     &kp F4     &kp F5            &kp F6      &kp F7     &kp F8     &kp F9     &kp F10
&bt BT_SEL 0   &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4 &tog UBASE &kp LC(B)  &kp LC(I)  &kp LC(U)  &kp F11
&bt BT_CLR     &kp LC(LA(DEL)) &kp LC(X) &kp LC(C) &kp LC(V) &none &out OUT_TOG &kp LC(A) &kp LC(S) &kp LC(P) &kp F12  &kp LA(F4)
                          &mo NAV    &mo NUM_J  &kp SPACE         &kp RET    &kp LSHFT  &kp LGUI
            >;
        };
    };
};
